rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Read the caller's role from their Firestore user document.
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && callerRole() == 'admin';
    }

    function isBank() {
      return isSignedIn() && callerRole() == 'bank';
    }

    function isApplicant() {
      return isSignedIn() && callerRole() == 'applicant';
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── BG Applications ────────────────────────────────────────────────────
    match /bg_applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.applicant_id == request.auth.uid ||
        isBank() ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        (isApplicant() && request.resource.data.applicant_id == request.auth.uid) ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        (isApplicant() && resource.data.applicant_id == request.auth.uid &&
          (resource.data.status == 'DRAFT' ||
           resource.data.status == 'OPEN' ||
           resource.data.status == 'QUOTED' ||
           resource.data.status == 'PROCESSING' ||
           resource.data.status == 'OFFER_ACCEPTED' ||
           resource.data.status == 'FD_REQUESTED' ||
           resource.data.status == 'FD_PAID' ||
           resource.data.status == 'BG_DRAFTING')) ||
        isBank() ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── BG Offers ──────────────────────────────────────────────────────────
    match /bg_offers/{offerId} {
      allow read: if isSignedIn() && (
        resource.data.applicant_id == request.auth.uid ||
        resource.data.bank_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && (isBank() || isAdmin());
      allow update: if isSignedIn() && (
        resource.data.bank_id == request.auth.uid ||
        resource.data.applicant_id == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── BG Messages ────────────────────────────────────────────────────────
    match /bg_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sender_id == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── BG Documents ───────────────────────────────────────────────────────
    match /bg_documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uploader_id == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── BG Payment Requests (FD / Bank Fees) ───────────────────────────────
    // Read is open to any signed-in user: queries by bg_doc_id need this,
    // and resource.data.* checks break queries / non-existent docs.
    match /bg_payment_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isBank();
      allow update: if isSignedIn() && (
        resource.data.bank_id == request.auth.uid ||
        resource.data.applicant_id == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Processing Fee Payments (to e-BGX) ─────────────────────────────────
    // Read is open to any signed-in user: getDoc of non-existent doc sets
    // resource=null, making resource.data.* throw and deny the read.
    match /bg_processing_fees/{bgDocId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isApplicant() || isAdmin());
      allow update: if isSignedIn() && (
        resource.data.applicant_id == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Settings (admin-managed, all authenticated can read) ───────────────
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Issued BGs ─────────────────────────────────────────────────────────
    match /issued_bgs/{bgId} {
      allow read: if isSignedIn() && (
        resource.data.applicant_id == request.auth.uid ||
        resource.data.bank_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && (isBank() || isAdmin());
      allow update: if isSignedIn() && (isBank() || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Bank Partners ──────────────────────────────────────────────────────
    match /bank_partners/{bankId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        resource.data.bank_id == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
        resource.data.user_id == request.auth.uid;
      allow create: if isAdmin() || isBank();
      allow update: if isSignedIn() &&
        resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.user_id == request.auth.uid;
    }

    // ─── Platform Config ────────────────────────────────────────────────────
    match /platform_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── BG Amendment / Renewal Requests ────────────────────────────────────
    match /bg_amendments/{amendId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.applicant_id == request.auth.uid ||
        isBank() ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        isApplicant() && request.resource.data.applicant_id == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (isBank() || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
